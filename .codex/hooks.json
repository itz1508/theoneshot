{
  "hooks": {
    "PreToolUse": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "uv run --no-sync --offline --directory openai_project/runtime python -m audisor.audisor_lifecycle.hook",
          "commandWindows": "uv run --no-sync --offline --directory openai_project/runtime python -m audisor.audisor_lifecycle.hook",
          "timeout": 30,
          "statusMessage": "Checking the A-Flow lock before repository mutation"
        }
      ]
    }
    ]
  }
}
