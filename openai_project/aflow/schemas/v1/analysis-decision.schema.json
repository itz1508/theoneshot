{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "A-Flow Analysis Decision",
  "description": "Final plan-analysis decision after structural validation and semantic finding substantiation.",
  "type": "object",
  "required": [
    "schema_version",
    "analysis_id",
    "success_definition_reference",
    "plan_reference",
    "decision",
    "blocking",
    "execution_ready",
    "findings",
    "rejected_findings",
    "decided_at",
    "content_hash"
  ],
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schema_version"
    },
    "analysis_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "success_definition_reference": {
      "$ref": "common.schema.json#/$defs/artifact_ref"
    },
    "plan_reference": {
      "$ref": "common.schema.json#/$defs/artifact_ref"
    },
    "decision": {
      "type": "string",
      "enum": [
        "no_material_gap",
        "material_gap_found",
        "missing_evidence",
        "contradicted",
        "drift_revalidation_required"
      ]
    },
    "blocking": {
      "type": "boolean"
    },
    "execution_ready": {
      "type": "boolean"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "finding.schema.json"
      }
    },
    "rejected_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "reason",
          "evidence_references"
        ],
        "properties": {
          "finding_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "evidence_references": {
            "type": "array",
            "items": {
              "$ref": "common.schema.json#/$defs/evidence_ref"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "decided_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "content_hash": {
      "$ref": "common.schema.json#/$defs/sha256"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "no_material_gap"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "blocking": {
            "const": false
          },
          "execution_ready": {
            "const": true
          },
          "findings": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "enum": [
              "material_gap_found",
              "missing_evidence",
              "contradicted",
              "drift_revalidation_required"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "blocking": {
            "const": true
          },
          "execution_ready": {
            "const": false
          },
          "findings": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$id": "https://theoneshot.dev/schemas/aflow/v1/analysis-decision.schema.json"
}
