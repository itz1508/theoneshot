{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "A-Flow Fixture Manifest",
  "description": "Metadata and safety boundary for one isolated behavioral fixture.",
  "type": "object",
  "required": [
    "schema_version",
    "fixture_id",
    "behavioral_principle",
    "stage",
    "scoring_category",
    "input_files",
    "expected_files",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schema_version"
    },
    "fixture_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "behavioral_principle": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "enum": [
        "schema_admission",
        "plan_analysis",
        "gap_closure",
        "drift",
        "final_evaluation"
      ]
    },
    "scoring_category": {
      "type": "string",
      "enum": [
        "true_positive_deterministic",
        "true_positive_semantic",
        "true_negative",
        "false_positive_rejection",
        "closure",
        "drift",
        "output_quality"
      ]
    },
    "input_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/relative_path"
      }
    },
    "expected_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/relative_path"
      }
    },
    "safety": {
      "type": "object",
      "required": [
        "network",
        "docker",
        "git_mutation",
        "target_mutation",
        "subprocess"
      ],
      "properties": {
        "network": {
          "const": false
        },
        "docker": {
          "const": false
        },
        "git_mutation": {
          "const": false
        },
        "target_mutation": {
          "const": false
        },
        "subprocess": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$id": "https://theoneshot.dev/schemas/aflow/v1/fixture-manifest.schema.json"
}
