{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "A-Flow Codex Plan",
  "description": "Versioned Codex plan bound to a locked success definition, authority bundle, and repository baseline.",
  "type": "object",
  "required": [
    "schema_version",
    "plan_id",
    "version",
    "created_by",
    "success_definition_reference",
    "objective",
    "interpretation",
    "repository_baseline_reference",
    "authority_bundle_reference",
    "target_paths",
    "excluded_paths",
    "requirements_coverage",
    "actions",
    "validations",
    "dependencies",
    "assumptions",
    "authority_risks",
    "failure_handling",
    "stop_conditions"
  ],
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schema_version"
    },
    "plan_id": {
      "$ref": "common.schema.json#/$defs/identifier"
    },
    "version": {
      "$ref": "common.schema.json#/$defs/semver"
    },
    "created_by": {
      "type": "string",
      "const": "codex"
    },
    "success_definition_reference": {
      "$ref": "common.schema.json#/$defs/artifact_ref"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "interpretation": {
      "type": "string",
      "minLength": 1
    },
    "repository_baseline_reference": {
      "$ref": "common.schema.json#/$defs/artifact_ref"
    },
    "authority_bundle_reference": {
      "$ref": "common.schema.json#/$defs/artifact_ref"
    },
    "target_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "reason",
          "authority_status"
        ],
        "properties": {
          "path": {
            "$ref": "common.schema.json#/$defs/relative_path"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "authority_status": {
            "type": "string",
            "enum": [
              "allowed",
              "requires_confirmation",
              "prohibited",
              "unknown"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "excluded_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "reason",
          "authority_status"
        ],
        "properties": {
          "path": {
            "$ref": "common.schema.json#/$defs/relative_path"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "authority_status": {
            "type": "string",
            "enum": [
              "allowed",
              "requires_confirmation",
              "prohibited",
              "unknown"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "requirements_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "requirement_id",
          "action_ids",
          "validation_ids"
        ],
        "properties": {
          "requirement_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "action_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "common.schema.json#/$defs/identifier"
            }
          },
          "validation_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "common.schema.json#/$defs/identifier"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "objective",
          "requirement_ids",
          "capability_id",
          "owner",
          "phase",
          "target_paths",
          "depends_on",
          "prerequisites",
          "activation",
          "expected_outputs"
        ],
        "properties": {
          "action_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "requirement_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "common.schema.json#/$defs/identifier"
            }
          },
          "capability_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "owner": {
            "type": "string",
            "enum": [
              "codex",
              "deterministic_local",
              "edge",
              "human"
            ]
          },
          "phase": {
            "$ref": "common.schema.json#/$defs/phase"
          },
          "target_paths": {
            "type": "array",
            "items": {
              "$ref": "common.schema.json#/$defs/relative_path"
            }
          },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "$ref": "common.schema.json#/$defs/identifier"
            }
          },
          "prerequisites": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "prerequisite_id",
                "condition",
                "status"
              ],
              "properties": {
                "prerequisite_id": {
                  "$ref": "common.schema.json#/$defs/identifier"
                },
                "condition": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "satisfied",
                    "unsatisfied",
                    "deferred",
                    "unknown"
                  ]
                },
                "evidence_refs": {
                  "type": "array",
                  "items": {
                    "$ref": "common.schema.json#/$defs/evidence_ref"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "activation": {
            "type": "object",
            "required": [
              "activation_type",
              "currently_authorized"
            ],
            "properties": {
              "activation_type": {
                "type": "string",
                "enum": [
                  "automatic",
                  "phase_entry",
                  "explicit_user_authorization",
                  "external_event",
                  "not_required"
                ]
              },
              "activation_source": {
                "type": "string",
                "minLength": 1
              },
              "currently_authorized": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "expected_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "output_id",
                "description"
              ],
              "properties": {
                "output_id": {
                  "$ref": "common.schema.json#/$defs/identifier"
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "artifact_path": {
                  "$ref": "common.schema.json#/$defs/relative_path"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "validations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "validation_id",
          "requirement_ids",
          "action_ids",
          "proof_id",
          "proof_type",
          "executor",
          "procedure",
          "pass_condition",
          "fail_condition",
          "evidence_expected"
        ],
        "properties": {
          "validation_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "requirement_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "common.schema.json#/$defs/identifier"
            }
          },
          "action_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "common.schema.json#/$defs/identifier"
            }
          },
          "proof_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "proof_type": {
            "$ref": "common.schema.json#/$defs/proof_type"
          },
          "executor": {
            "$ref": "common.schema.json#/$defs/executor"
          },
          "procedure": {
            "type": "string",
            "minLength": 1
          },
          "pass_condition": {
            "type": "string",
            "minLength": 1
          },
          "fail_condition": {
            "type": "string",
            "minLength": 1
          },
          "required_environment": {
            "type": "string",
            "minLength": 1
          },
          "evidence_expected": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "file_content",
                "file_metadata",
                "command_result",
                "test_result",
                "api_response",
                "artifact",
                "user_confirmation",
                "schema_result",
                "repository_snapshot",
                "authority_document",
                "semantic_review",
                "human_observation"
              ]
            }
          }
        },
        "additionalProperties": false
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dependency_id",
          "description",
          "source",
          "status"
        ],
        "properties": {
          "dependency_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "$ref": "common.schema.json#/$defs/source_reference"
          },
          "status": {
            "type": "string",
            "enum": [
              "resolved",
              "unresolved",
              "not_required"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "assumption_id",
          "statement",
          "status"
        ],
        "properties": {
          "assumption_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "substantiated",
              "unsubstantiated",
              "rejected"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "$ref": "common.schema.json#/$defs/evidence_ref"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "authority_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "risk_id",
          "description",
          "status"
        ],
        "properties": {
          "risk_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "resolved",
              "unresolved",
              "none_identified"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "$ref": "common.schema.json#/$defs/evidence_ref"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "failure_handling": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "failure_id",
          "condition",
          "action",
          "recovery_condition"
        ],
        "properties": {
          "failure_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": [
              "block",
              "isolate",
              "return_to_codex",
              "abandon_build"
            ]
          },
          "recovery_condition": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "stop_id",
          "condition",
          "effect",
          "resume_condition"
        ],
        "properties": {
          "stop_id": {
            "$ref": "common.schema.json#/$defs/identifier"
          },
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "effect": {
            "type": "string",
            "enum": [
              "stop_action",
              "stop_phase",
              "stop_execution"
            ]
          },
          "resume_condition": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "path_scope": {
      "type": "object",
      "required": [
        "path",
        "reason",
        "authority_status"
      ],
      "properties": {
        "path": {
          "$ref": "common.schema.json#/$defs/relative_path"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "authority_status": {
          "type": "string",
          "enum": [
            "allowed",
            "requires_confirmation",
            "prohibited",
            "unknown"
          ]
        }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": [
        "action_id",
        "objective",
        "requirement_ids",
        "capability_id",
        "owner",
        "phase",
        "target_paths",
        "depends_on",
        "prerequisites",
        "activation",
        "expected_outputs"
      ],
      "properties": {
        "action_id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "requirement_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        },
        "capability_id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "owner": {
          "type": "string",
          "enum": [
            "codex",
            "deterministic_local",
            "edge",
            "human"
          ]
        },
        "phase": {
          "$ref": "common.schema.json#/$defs/phase"
        },
        "target_paths": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/relative_path"
          }
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "prerequisite_id",
              "condition",
              "status"
            ],
            "properties": {
              "prerequisite_id": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "condition": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "satisfied",
                  "unsatisfied",
                  "deferred",
                  "unknown"
                ]
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "$ref": "common.schema.json#/$defs/evidence_ref"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "activation": {
          "type": "object",
          "required": [
            "activation_type",
            "currently_authorized"
          ],
          "properties": {
            "activation_type": {
              "type": "string",
              "enum": [
                "automatic",
                "phase_entry",
                "explicit_user_authorization",
                "external_event",
                "not_required"
              ]
            },
            "activation_source": {
              "type": "string",
              "minLength": 1
            },
            "currently_authorized": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "expected_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "output_id",
              "description"
            ],
            "properties": {
              "output_id": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "artifact_path": {
                "$ref": "common.schema.json#/$defs/relative_path"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": [
        "validation_id",
        "requirement_ids",
        "action_ids",
        "proof_id",
        "proof_type",
        "executor",
        "procedure",
        "pass_condition",
        "fail_condition",
        "evidence_expected"
      ],
      "properties": {
        "validation_id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "requirement_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        },
        "action_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        },
        "proof_id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "proof_type": {
          "$ref": "common.schema.json#/$defs/proof_type"
        },
        "executor": {
          "$ref": "common.schema.json#/$defs/executor"
        },
        "procedure": {
          "type": "string",
          "minLength": 1
        },
        "pass_condition": {
          "type": "string",
          "minLength": 1
        },
        "fail_condition": {
          "type": "string",
          "minLength": 1
        },
        "required_environment": {
          "type": "string",
          "minLength": 1
        },
        "evidence_expected": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "file_content",
              "file_metadata",
              "command_result",
              "test_result",
              "api_response",
              "artifact",
              "user_confirmation",
              "schema_result",
              "repository_snapshot",
              "authority_document",
              "semantic_review",
              "human_observation"
            ]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$id": "https://theoneshot.dev/schemas/aflow/v1/plan.schema.json"
}
