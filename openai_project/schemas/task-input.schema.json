{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audisor.local/schemas/task-input.schema.json",
  "title": "Audisor task input batch",
  "description": "An AMD-compatible non-empty task batch. Duplicate task_id values are rejected by runtime validation.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["task_id", "prompt"],
    "properties": {
      "task_id": {
        "type": "string",
        "pattern": "\\S"
      },
      "prompt": {
        "type": "string",
        "pattern": "\\S"
      }
    },
    "additionalProperties": true
  },
  "x-audisor-uniqueBy": "task_id"
}
