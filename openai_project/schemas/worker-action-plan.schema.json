{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audisor.local/schemas/worker-action-plan.schema.json",
  "title": "Phase 2B worker action plan",
  "type": "object",
  "required": ["summary", "mutations", "expected_changed_paths"],
  "properties": {
    "summary": {"type": "string", "minLength": 1, "maxLength": 4000},
    "mutations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"$ref": "#/$defs/mutation"}
    },
    "expected_changed_paths": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/relativePath"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "actionId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?![Cc][Oo][Nn](?:\\..*)?$)(?![Pp][Rr][Nn](?:\\..*)?$)(?![Aa][Uu][Xx](?:\\..*)?$)(?![Nn][Uu][Ll](?:\\..*)?$)(?![Cc][Oo][Mm][1-9](?:\\..*)?$)(?![Ll][Pp][Tt][1-9](?:\\..*)?$)[A-Za-z0-9](?:[A-Za-z0-9._-]{0,62}[A-Za-z0-9])?$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?![/\\\\])(?![A-Za-z]:)(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*:).+$"
    },
    "mutation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["action_id", "type", "path", "content"],
          "properties": {
            "action_id": {"$ref": "#/$defs/actionId"},
            "type": {"const": "write_file"},
            "path": {"$ref": "#/$defs/relativePath"},
            "content": {"type": "string", "maxLength": 1000000}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["action_id", "type", "path"],
          "properties": {
            "action_id": {"$ref": "#/$defs/actionId"},
            "type": {"const": "create_directory"},
            "path": {"$ref": "#/$defs/relativePath"}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["action_id", "type", "path"],
          "properties": {
            "action_id": {"$ref": "#/$defs/actionId"},
            "type": {"const": "delete_file"},
            "path": {"$ref": "#/$defs/relativePath"}
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
