{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audisor.local/schemas/build-execution-input.schema.json",
  "title": "Prepared build execution request",
  "type": "object",
  "required": ["execution_id", "idempotency_key", "target_root", "allowed_write_paths"],
  "properties": {
    "execution_id": {"$ref": "#/$defs/safeIdentifier"},
    "idempotency_key": {"$ref": "#/$defs/safeIdentifier"},
    "target_root": {"type": "string", "minLength": 1, "maxLength": 32767},
    "allowed_write_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/safeRelativePath"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "safeIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?![Cc][Oo][Nn](?:\\..*)?$)(?![Pp][Rr][Nn](?:\\..*)?$)(?![Aa][Uu][Xx](?:\\..*)?$)(?![Nn][Uu][Ll](?:\\..*)?$)(?![Cc][Oo][Mm][1-9](?:\\..*)?$)(?![Ll][Pp][Tt][1-9](?:\\..*)?$)[A-Za-z0-9](?:[A-Za-z0-9._-]{0,62}[A-Za-z0-9])?$"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?![/\\\\])(?![A-Za-z]:)(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*:).+$"
    }
  }
}
