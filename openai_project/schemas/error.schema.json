{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audisor.local/schemas/error.schema.json",
  "title": "Audisor HTTP error response",
  "oneOf": [
    {
      "title": "Validation error",
      "type": "object",
      "required": ["detail"],
      "properties": {
        "detail": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "loc", "msg", "input"],
            "properties": {
              "type": {"type": "string"},
              "loc": {
                "type": "array",
                "items": {"type": ["string", "integer"]}
              },
              "msg": {"type": "string"},
              "input": {},
              "ctx": {"type": "object"},
              "url": {"type": "string"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Worker error",
      "type": "object",
      "required": ["detail"],
      "properties": {
        "detail": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": {"type": "string", "minLength": 1},
            "message": {"type": "string"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}
