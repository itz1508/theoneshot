{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audisor.local/schemas/build-input.schema.json",
  "title": "Audisor build preparation request",
  "type": "object",
  "required": ["build_id", "instruction"],
  "properties": {
    "build_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?![Cc][Oo][Nn](?:\\..*)?$)(?![Pp][Rr][Nn](?:\\..*)?$)(?![Aa][Uu][Xx](?:\\..*)?$)(?![Nn][Uu][Ll](?:\\..*)?$)(?![Cc][Oo][Mm][1-9](?:\\..*)?$)(?![Ll][Pp][Tt][1-9](?:\\..*)?$)[A-Za-z0-9](?:[A-Za-z0-9._-]{0,62}[A-Za-z0-9])?$"
    },
    "instruction": {
      "type": "string",
      "maxLength": 100000,
      "pattern": "\\S"
    }
  },
  "additionalProperties": false
}

