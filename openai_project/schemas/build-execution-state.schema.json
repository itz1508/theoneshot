{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audisor.local/schemas/build-execution-state.schema.json",
  "title": "Prepared build execution state",
  "type": "object",
  "required": ["build_id", "execution_id", "status", "tasks"],
  "properties": {
    "build_id": {"$ref": "#/$defs/identifier"},
    "execution_id": {"$ref": "#/$defs/identifier"},
    "status": {"enum": ["running", "completed", "failed", "interrupted", "not_valid"]},
    "terminal_manifest_sha256": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "description": "Task IDs are additionally unique case-insensitively at the runtime and durable reconciliation boundaries; standard JSON Schema uniqueItems can enforce only whole-record uniqueness.",
      "x-unique-by": "task_id",
      "items": {
        "type": "object",
        "required": ["task_id", "status"],
        "properties": {
          "task_id": {"$ref": "#/$defs/identifier"},
          "status": {
            "enum": ["pending", "ready", "running", "completed", "failed", "blocked", "interrupted"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "completed"}}, "required": ["status"]},
      "then": {
        "required": ["terminal_manifest_sha256"],
        "properties": {
          "terminal_manifest_sha256": {"type": "string"},
          "tasks": {"items": {"properties": {"status": {"const": "completed"}}}}
        }
      }
    },
    {
      "if": {"properties": {"status": {"const": "failed"}}, "required": ["status"]},
      "then": {
        "required": ["terminal_manifest_sha256"],
        "properties": {
          "terminal_manifest_sha256": {"type": "string"},
          "tasks": {
            "contains": {"properties": {"status": {"const": "failed"}}, "required": ["status"]},
            "items": {"properties": {"status": {"enum": ["completed", "failed", "blocked", "interrupted"]}}}
          }
        }
      }
    },
    {
      "if": {"properties": {"status": {"const": "interrupted"}}, "required": ["status"]},
      "then": {
        "properties": {
          "tasks": {
            "contains": {"properties": {"status": {"const": "interrupted"}}, "required": ["status"]},
            "items": {"properties": {"status": {"enum": ["completed", "failed", "blocked", "interrupted"]}}}
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?![Cc][Oo][Nn](?:\\..*)?$)(?![Pp][Rr][Nn](?:\\..*)?$)(?![Aa][Uu][Xx](?:\\..*)?$)(?![Nn][Uu][Ll](?:\\..*)?$)(?![Cc][Oo][Mm][1-9](?:\\..*)?$)(?![Ll][Pp][Tt][1-9](?:\\..*)?$)[A-Za-z0-9](?:[A-Za-z0-9._-]{0,62}[A-Za-z0-9])?$"
    }
  },
  "additionalProperties": false
}
